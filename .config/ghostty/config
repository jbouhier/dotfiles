# Window
window-height = 500
window-width = 1000
window-padding-x = 10
window-padding-y = 10
background-opacity = 0.85
background-blur = 30
window-theme = dark
window-save-state = never
window-decoration = false

# Colors
theme = tokyonight

# Font
font-family = "Fira Code"
font-style = "Medium"
font-size = 21

# Shell 
command = /opt/homebrew/bin/fish
shell-integration = detect
scrollback-limit = 10000

# Cursor
cursor-style = block
cursor-style-blink = false

